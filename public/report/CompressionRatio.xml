<?xml version="1.0" encoding="utf-8"?>
<root>
  <!--报表标题-->
  <ReportTitle title="告警压缩率" />
  
  <!--查询sql-->
  <!--例子Start-->
  <sql dbName="nmosdb" sqlId="Select_AlmRpt_CompressionRatio_ByPage">
    <!--当是informax时：#BegeinIndex#表示分页起点位置（即skip的条数）,#Count#取的条数；当是oracle时：#BegeinIndex#表示分页起点位置，#EndIndex#表示分页结束的位置-->
    <!--如果是oracle库，时间格式写成to_date(#Time#,'yyyy-MM-dd HH24:mi:ss'),informix库就不需要修改-->
  </sql>
  <!--例子End-->
  
  <!--汇总sql-->
  <!--例子Start-->
  <countsql sqlId="Select_AlmRpt_CompressionRatio_Count">
  </countsql>
  <!--例子End-->
  
  <!--查询条件-->
  <Conditions>
   <!--Name：控件说明，Flag：唯一标示不允许重复并与上面sql中where条件未知参数相同，BindType：绑定类型（sql|enmu|time），ControlType：标准控件名称,DbName:数据库名称-->
    <!--ControlType说明  （时间：DatePicker||单选下拉框:ComboBox||文本框：textbox||多选下拉框：MutiDropDown）-->
    <!--BindType说明  （BindType=sql中字段别名采用text ,value||BindType=enmu 前面是显示文本，后面是ID||BindType="" 不需要初始化数据）-->
    <!--DefaultValue： 控件的默认值，目前时间控件提供：当月（当前时间所在月第一天）；当周（当前时间所在周第一天）；当日（当前时间所在天）；上月（当前时间所在月的上月第一天）-->
    <!--例子 Start-->
    <Condition Name="起止时间" Flag="timeRange"  ControlType="DateTimePickerRange" DefaultValue="上月,当日">
    </Condition>
    <Condition Name="时间粒度" Flag="sum_level" BindType="enmu" ControlType="ComboBox" TriggerEvent="True" DefaultValue="1"  
              sqlId = "Select_AlmRpt_CompressionRatio_CondSumLevel">
      日,1|月,3
    </Condition> 
    <Condition Name="站段" Flag="province" BindType="sql" ControlType="MutiDropDown" DbName="nmosdb"
            sqlId = "Select_AlmRpt_CompressionRatio_CondProvince">
      select distinct province_id value,province_name text from region_city order by province_name
    </Condition>  
    <!--例子 End-->

  </Conditions>
  
  <!--显示列-->
  <Columns>
    <!--FieldName与上面的sql字段的别名相同（除了包含子级的父节点），不可以重复,包含子节点的Column节点中的FieldName字段不重复-->
    <!--IsSort 排序图标（false不进行排序-可以不写，true进行排序）-->
 
    <!--多级表头例子-->
    <!--例子 Start-->
    <!--不分级列-->
    <ColumnItem FieldName="w1" DisplayName="时间" IsSort="true"></ColumnItem>
    <ColumnItem FieldName="w2" DisplayName="站段" IsSort="false"></ColumnItem>
    <ColumnItem FieldName="w8" DisplayName="专业" IsSort="false"></ColumnItem>
  	<ColumnItem FieldName="w12" DisplayName="告警压缩率" IsSort="false"></ColumnItem>	
    <ColumnItem FieldName="w9" DisplayName="告警总量" IsSort="false"></ColumnItem> 	
    <ColumnItem FieldName="w4" DisplayName="实际派单告警量" IsSort="false"></ColumnItem>  
    <ColumnItem FieldName="w5" DisplayName="总派单工单量" IsSort="false"></ColumnItem>
  </Columns>
</root>