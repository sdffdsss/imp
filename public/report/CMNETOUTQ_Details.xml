<?xml version="1.0" encoding="utf-8"?>
<root>
  <!--报表标题-->
  <ReportTitle title="cmnet互联出口质量日报表" />
  
  <!--查询sql-->
  <!--例子Start-->
  <sql dbName="nmosdb_pg" sqlId = "Select_CMNETOUTQ_Details_ByPage">
  </sql>
  <!--例子End-->
  
  <!--汇总sql-->
  <!--例子Start-->
  <countsql dbName="nmosdb_pg" sqlId = "Select_CMNETOUTQ_Details_Count">
  </countsql>
  <!--例子End-->
  
  <!--查询条件-->
  <Conditions>
   <!--Name：控件说明，Flag：唯一标示不允许重复并与上面sql中where条件未知参数相同，BindType：绑定类型（sql|enmu|time），ControlType：标准控件名称,DbName:数据库名称-->
    <!--ControlType说明  （时间：DatePicker||单选下拉框:ComboBox||文本框：textbox||多选下拉框：MutiDropDown）-->
    <!--BindType说明  （BindType=sql中字段别名采用text ,value||BindType=enmu 前面是显示文本，后面是ID||BindType="" 不需要初始化数据）-->
    
    <!--例子 Start-->
    <Condition Name="时间粒度" Flag="sum_level" BindType="enmu" ControlType="ComboBox" TriggerEvent="True"  DefaultValue="1" DbName="nmosdb_pg"  sqlId = "Select_ProNetIDCExDetails_CondSumLevel">
      日,1|周,2|月,3
    </Condition> 
    <!-- <Condition Name="起止时间" Flag="timeRange"  ControlType="DatePickerRange" DefaultValue="当日,当日">
    </Condition> -->
    <!--例子 End-->

  </Conditions>
  
  <!--显示列-->
  <Columns>
    <!--FieldName与上面的sql字段的别名相同（除了包含子级的父节点），不可以重复,包含子节点的Column节点中的FieldName字段不重复-->
    <!--IsSort 排序图标（false不进行排序-可以不写，true进行排序）-->
    <!--多级表头例子-->
    <!--例子 Start-->
    <!--不分级列-->
    <ColumnItem FieldName="w1" DisplayName="统计时间" IsSort="true"></ColumnItem>
    <ColumnItem FieldName="w2" DisplayName="链路标识" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w3" DisplayName="链路带宽(Mbps)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w4" DisplayName="出口转接商" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w5" DisplayName="对端运营商" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w6" DisplayName="流入平均流速(Mbps)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w7" DisplayName="流入忙时流速(Mbps)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w8" DisplayName="流出平均流速(Mbps)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w9" DisplayName="流出忙时流速(Mbps)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w10" DisplayName="流入平均带宽利用率(%)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w11" DisplayName="流入忙时带宽利用率(%)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w12" DisplayName="流出平均带宽利用率(%)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w13" DisplayName="流出忙时带宽利用率(%)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w14" DisplayName="平均时延(ms)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w15" DisplayName="忙时时延(ms)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w16" DisplayName="平均丢包率(%)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w17" DisplayName="忙时丢包率(%)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w18" DisplayName="流入峰值时段" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w19" DisplayName="流入日峰值速率(Mbps)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w20" DisplayName="流入日峰值带宽利用率(%)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w21" DisplayName="流入峰值时段时延(ms)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w22" DisplayName="流入峰值时段丢包率(%)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w23" DisplayName="流出峰值时段" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w24" DisplayName="流出日峰值速率(Mbps)" IsSort="false" Width ="150"></ColumnItem>
    <ColumnItem FieldName="w25" DisplayName="流出日峰值带宽利用率(%)" IsSort="false" Width ="150"></ColumnItem>
