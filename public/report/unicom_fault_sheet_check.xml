  <!--查询条件-->
  <Conditions>
   <!--Name：控件说明，Flag：唯一标示不允许重复并与上面sql中where条件未知参数相同，BindType：绑定类型（sql|enmu|time），ControlType：标准控件名称,DbName:数据库名称-->
    <!--ControlType说明  （时间：DatePicker||单选下拉框:ComboBox||文本框：textbox||多选下拉框：MutiDropDown）-->
    <!--BindType说明  （BindType=sql中字段别名采用text ,value||BindType=enmu 前面是显示文本，后面是ID||BindType="" 不需要初始化数据）-->

    <!--省份-->
    <Condition watch='1' Name="省份" Flag="province" Authority="province_id" ControlType="MutiDropDown" DbName="nmosdb_mysql"
   					FirstOptionSelected=""
            sqlId = "Select_AlmRpt_CompressionRatio_Unicom_CondProvince">
    </Condition>
    <!--地市-->
    <Condition Name="地市" Flag="region" Authority="region_id"  ControlType="ComboBox" DbName="nmosdb_mysql" 
            effect="province|id|province_id"
            sqlId="Select_AlmRpt_CompressionRatio_Unicom_CondRegion">
    </Condition>
    <!--专业-->
    <Condition Name="专业" Flag="profession"  ControlType="ComboBox" DbName="nmosdb_mysql" DefaultValue="8"
            sqlId = "Select_AlmRpt_CompressionRatio_Unicom_CondProfession">
    </Condition>
    <!--派单规则-->
    派单规则：<Condition Name="派单规则"  Flag="rules"  ControlType="textbox" >
    </Condition>
    <!--时间范围-->
    <Condition Name="起止时间" Flag="timeRange"  ControlType="DatePickerRange" DefaultValue="昨日,昨日">
    </Condition>





  </Conditions>



  <!--显示列-->
  <Columns Authority="region_id|province_id" SearchCollapsed='true'>
