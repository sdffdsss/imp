{
    "name": "oss-imp-unicom",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "analyz": "cross-env NODE_ENV=production NPM_CONFIG_FlAG=true npm run build",
        "build": "node --max-old-space-size=12288 scripts/build.js",
        "build:nomap": "cross-env GENERATE_SOURCEMAP=false node --max-old-space-size=12288 scripts/build.js",
        "build:nomap:canary": "cross-env GENERATE_SOURCEMAP=false DEPLOY_ENV=canary node --max-old-space-size=12288 scripts/build.js",
        "build:nomap:prod": "cross-env GENERATE_SOURCEMAP=false DEPLOY_ENV=prod node --max-old-space-size=12288 scripts/build.js",
        "build:notopoimg": "cross-env REACT_APP_NO_TOPO_IMG=true node --max-old-space-size=12288  scripts/build.js",
        "build:tianjin": "cross-env REACT_APP_PROVINCE=tianjin node scripts/build.js",
        "prepare": "husky install",
        "start": "node --max-old-space-size=4096 scripts/start.js",
        "start:run-in-framework": "cross-env PORT=5412 node --max-old-space-size=4096 scripts/start.js",
        "test": "node scripts/test.js"
    },
    "babel": {
        "plugins": [
            [
                "babel-plugin-import",
                {
                    "libraryName": "oss-ui",
                    "libraryDirectory": "es",
                    "style": false
                }
            ]
        ],
        "presets": [
            "react-app"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all",
            "ie > 9"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version",
            "ie > 9"
        ]
    },
    "jest": {
        "collectCoverageFrom": [
            "src/**/*.{js,jsx,ts,tsx}",
            "!src/**/*.d.ts"
        ],
        "moduleFileExtensions": [
            "web.js",
            "js",
            "web.ts",
            "ts",
            "web.tsx",
            "tsx",
            "json",
            "web.jsx",
            "jsx",
            "node"
        ],
        "moduleNameMapper": {
            "^react-native$": "react-native-web",
            "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy"
        },
        "modulePaths": [],
        "roots": [
            "<rootDir>/src"
        ],
        "setupFiles": [
            "react-app-polyfill/jsdom"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/src/setupTests.js"
        ],
        "testEnvironment": "jest-environment-jsdom-fourteen",
        "testMatch": [
            "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
            "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
        ],
        "transform": {
            "^.+\\.(js|jsx|ts|tsx)$": "<rootDir>/node_modules/babel-jest",
            "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
            "^(?!.*\\.(js|jsx|ts|tsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
        },
        "transformIgnorePatterns": [
            "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$",
            "^.+\\.module\\.(css|sass|scss)$"
        ],
        "watchPlugins": [
            "jest-watch-typeahead/filename",
            "jest-watch-typeahead/testname"
        ]
    },
    "resolutions": {
        "@monaco-editor/react": "4.4.5",
        "@types/react": "16.14.43",
